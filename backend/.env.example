# MongoDB Atlas Connection String
# Get your connection string from MongoDB Atlas dashboard
# Format: mongodb+srv://<username>:<password>@<cluster-url>/<database-name>?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/tradein_db?retryWrites=true&w=majority

# JWT Secret Key
# Generate a strong random secret key for production
# You can use: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# JWT Expiration Time
# Format: 1h, 24h, 7d, 30d, etc.
JWT_EXPIRE=30d

# Server Port
PORT=5000

# Node Environment
# Options: development, production, test
NODE_ENV=development
